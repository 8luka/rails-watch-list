<div class="navbar navbar-expand-sm navbar-light navbar-lewagon">
  <div class="container-fluid">

    <%= link_to 'Back', lists_path, class: 'btn btn-secondary mt-3'  %>
    <h1><%= @list.name %></h1>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto">
          <li class="nav-item active">
            <%= link_to "Add Movie", new_list_bookmark_path(@list), class: 'btn btn-info'  %>
          </li>
          <li class="nav-item">
            <%# <a class="nav-link" href="#">Messages</a> %>
          </li>
      </ul>
    </div>
  </div>
</div>

<div class="container my-5">
  <%# TODO: show movies in this list %>
  <div class="cards">
    <% @list.bookmarks.each do |bookmark| %>
      <div class="card" style="width: 18rem;">
        <%= image_tag bookmark.movie.poster_url, alt: "text", class: "card-img-top" %>
        <div class="card-body">
          <p class="card-text"><%= bookmark.comment %></p>
        </div>
        <%= link_to "Remove", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Remove this film?", class:"nav-link" }  %>
      </div>
    <% end %>
  </div>
</div>
