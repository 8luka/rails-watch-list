<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @list.name %></h1>
  <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-primary" %>
</div>

<% @list.bookmarks.each do |bookmark| %>
<div class="card-movie">
  <%= image_tag bookmark.movie.poster_url %>
  <div class="card-movie-infos">
    <div>
      <h2><%= bookmark.movie.title %></h2>
      <p><%= bookmark.comment %></p>
    </div>
    <%= link_to "Remove", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Remove this film?", class:"nav-link" }  %>
  </div>
</div>
<% end %>
